{
  "appId": "com.cometix.codemap",
  "productName": "Codemap Explorer",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/standalone/**/*",
    "package.json"
  ],
  "main": "dist/standalone/main.js",
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Development",
    "icon": "build/icon.png"
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.developer-tools",
    "icon": "build/icon.icns"
  },
  "win": {
    "target": ["nsis"],
    "icon": "build/icon.ico"
  }
}
