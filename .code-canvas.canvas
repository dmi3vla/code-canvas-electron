      "language": "javascript",
      "content": "function ensureTraceAreas() { const byArea = new Map(); for (const node of state.nodes) { if (node.type === 'group') continue; const key = nodeAreaKey(node); if (!key) continue; if (!byArea.has(key)) byArea.set(key, []); byArea.get(key).push(node); } ... for (const [areaKey, children] of byArea) { ... state.nodes.push({ id: areaKey, type: 'group', title, ...bounds, areaId: areaKey, color: palette.accent, fill: palette.fill, border: palette.border, zIndex: 0 }); } }\nГруппировка нод по areaId/traceId, пересчёт bounding box с отступами, создание/обновление group-нод с палитрой",
