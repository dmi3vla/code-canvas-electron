      "content": "window.addEventListener('mouseup', (event) => { if (state.interaction.link) { const target = event.target instanceof Element ? event.target : null; const connector = target?.closest('.connector'); const nodeEl = target?.closest('.node'); if (connector && nodeEl) { addEdge(state.interaction.link.fromNodeId, toNodeId, state.interaction.link.fromSide, toSide, state.mode === 'link' ? 'link' : ''); } } ... });\nВ режиме Link: перетаскивание от коннектора к коннектору → addEdge с указанием сторон",
      "x": 1120,
