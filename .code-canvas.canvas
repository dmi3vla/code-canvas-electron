      "color": "#b2f2bb",
      "language": "javascript",
      "content": "root.addEventListener('wheel', (event) => { event.preventDefault(); const cursor = worldFromClient(event.clientX, event.clientY); const delta = event.deltaY < 0 ? 1.08 : 0.92; const newScale = Math.max(0.25, Math.min(2.5, state.view.scale * delta)); state.view.x = event.clientX - root.getBoundingClientRect().left - cursor.x * newScale; state.view.y = event.clientY - root.getBoundingClientRect().top - cursor.y * newScale; state.view.scale = newScale; render(); }, { passive: false });\nМасштабирование относительно позиции курсора с ограничением 0.25x–2.5x",
