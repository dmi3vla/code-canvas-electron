      "color": "#b2f2bb",
      "language": "javascript",
      "content": "function autoLayout() { const contentNodes = state.nodes.filter((n) => n.type !== 'group' && nodeAreaKey(n)); if (contentNodes.length) { const byArea = new Map(); for (const node of contentNodes) { const key = nodeAreaKey(node); if (!byArea.has(key)) byArea.set(key, []); byArea.get(key).push(node); } ... let cursorY = 0; for (const [, children] of byArea) { children.sort((a, b) => String(a.locationId || a.id).localeCompare(String(b.locationId || b.id))); children.forEach((node, i) => { node.x = PAD_X + i * COL; node.y = cursorY + TITLE_H + PAD_Y; }); cursorY += areaH + GAP_Y; } state.nodes = state.nodes.filter((n) => n.type !== 'group'); } render(); }\nСемантическая раскладка: области вертикально, локации внутри области — горизонтально слева направо",
