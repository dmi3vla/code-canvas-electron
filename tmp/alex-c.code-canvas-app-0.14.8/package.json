{
	"name": "code-canvas-app",
	"displayName": "code canvas app",
	"icon": "icon.png",
	"description": "See your code on an infinite canvas",
	"version": "0.14.8",
	"engines": {
		"vscode": "^1.93.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"*"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "codeCanvas.openCanvas",
				"title": "Open Code Canvas",
				"icon": "$(graph)"
			},
			{
				"command": "codeCanvas.openInCanvas",
				"title": "Open in Code Canvas"
			},
			{
				"command": "codeCanvas.refreshTree",
				"title": "Refresh",
				"icon": "$(refresh)"
			},
			{
				"command": "codeCanvas.collapseAll",
				"title": "Collapse All Folders",
				"icon": "$(collapse-all)"
			},
			{
				"command": "codeCanvas.expandAll",
				"title": "Expand All Folders",
				"icon": "$(expand-all)"
			},
			{
				"command": "codeCanvas.addToCanvas",
				"title": "Add to Canvas",
				"icon": "$(add)"
			},
			{
				"command": "codeCanvas.newFile",
				"title": "New File",
				"icon": "$(new-file)"
			},
			{
				"command": "codeCanvas.newFolder",
				"title": "New Folder",
				"icon": "$(new-folder)"
			},
			{
				"command": "codeCanvas.rename",
				"title": "Rename",
				"icon": "$(edit)"
			},
			{
				"command": "codeCanvas.delete",
				"title": "Delete",
				"icon": "$(trash)"
			},
			{
				"command": "codeCanvas.copyPath",
				"title": "Copy Path"
			},
			{
				"command": "codeCanvas.copyRelativePath",
				"title": "Copy Relative Path"
			},
			{
				"command": "codeCanvas.openInEditor",
				"title": "Open in Editor",
				"icon": "$(go-to-file)"
			},
			{
				"command": "codeCanvas.revealInExplorer",
				"title": "Reveal in Explorer"
			},
			{
				"command": "codeCanvas.showEditorTokenReferences",
				"title": "Code Canvas: Show Token References on Canvas"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "codeCanvas.refreshTree",
					"when": "view == codeCanvasTree",
					"group": "navigation@1"
				},
				{
					"command": "codeCanvas.collapseAll",
					"when": "view == codeCanvasTree",
					"group": "navigation@2"
				},
				{
					"command": "codeCanvas.expandAll",
					"when": "view == codeCanvasTree",
					"group": "navigation@3"
				}
			],
			"explorer/context": [
				{
					"command": "codeCanvas.openInCanvas",
					"group": "navigation"
				}
			],
			"commandPalette": [
				{
					"command": "codeCanvas.openInCanvas",
					"when": "explorerViewletVisible"
				}
			],
			"titleBar": [
				{
					"command": "codeCanvas.openCanvas",
					"group": "navigation"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "code-canvas",
					"title": "Code Canvas",
					"icon": "$(graph)"
				}
			]
		},
		"configuration": {
			"title": "Code Canvas",
			"properties": {
				"codeCanvas.autoOpenOnStartup": {
					"type": "boolean",
					"default": false,
					"description": "Automatically open the Code Canvas panel when VS Code starts"
				},
				"codeCanvas.autoOpenChangedFiles": {
					"type": "boolean",
					"default": true,
					"description": "When a file is edited (code inside a file is modified), automatically open it in the canvas if not already open"
				},
				"codeCanvas.fileWatcherEnabled": {
					"type": "boolean",
					"default": true,
					"description": "Watch workspace files for changes so they automatically update on the canvas. This updates files when switching branches as well"
				},
				"codeCanvas.telemetry.enabled": {
					"type": "boolean",
					"default": false,
					"description": "Enable anonymous usage telemetry to help improve Code Canvas. No source code or personal information is collected.",
					"tags": [
						"telemetry",
						"usesOnlineServices"
					]
				},
				"codeCanvas.ignoreFiles": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional file names to ignore when scanning folders (e.g., ['package.json', 'tsconfig.json']). These are merged with default ignore patterns."
				},
				"codeCanvas.ignoreDirectories": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional directory names to ignore when scanning folders (e.g., ['node_modules', 'dist']). These are merged with default ignore patterns."
				},
				"codeCanvas.ignoreExtensions": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional file extensions to ignore when scanning folders (e.g., ['.png', '.jpg']). These are merged with default ignore patterns."
				},
				"codeCanvas.ignoreRegexPatterns": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional regex patterns to match against file names for ignoring (e.g., ['\\.tmp\\.', '^vite\\.config\\.ts\\.timestamp-']). These are merged with default ignore patterns."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "cross-env NODE_ENV=production NO_SOURCEMAP=true concurrently \"webpack --config webpack.extension.config.js --mode production\" \"webpack --config webpack.webview.config.js --mode production\"",
		"-----------------------------------------------------------": "-----------------------------------------------------------",
		"watch:dev": "rm -rf node_modules/ && npm i && rm -rf dist/ && npm run env:dev:alex && cross-env NODE_ENV=development concurrently \"webpack --config webpack.extension.config.js --watch\" \"webpack --config webpack.webview.config.js --watch\"",
		"watch:prod": "rm -rf node_modules/ && npm i && rm -rf dist/ && npm run env:prod && cross-env NODE_ENV=production concurrently \"webpack --config webpack.extension.config.js --watch\" \"webpack --config webpack.webview.config.js --watch\"",
		"watch:profile": "rm -rf node_modules/ && npm i && rm -rf dist/ && npm run env:dev:alex && cross-env NODE_ENV=production PROFILE=true concurrently \"webpack --config webpack.extension.config.js --watch\" \"webpack --config webpack.webview.config.js --watch\"",
		"----------------------------------------------------------": "----------------------------------------------------------",
		"env:dev:alex": "bash ./scripts/setup-env.sh dev alex",
		"env:prod": "bash ./scripts/setup-env.sh prod",
		"---------------------------------------------------------": "---------------------------------------------------------",
		"package:prod:clean": "rm -rf node_modules/ && npm i && npm run env:prod && bash ./scripts/package-extension.sh",
		"package:dev:clean": "rm -rf node_modules/ && npm i && npm run env:dev:alex && bash ./scripts/package-extension.sh",
		"publish": "bash ./scripts/publish-extension.sh",
		"--------------------------------------------------------": "--------------------------------------------------------",
		"test": "mocha -r tsx -r ./src/backend/fileData/tests/setup.ts src/**/*.test.ts",
		"format": "prettier --write .",
		"lint": "eslint src"
	},
	"devDependencies": {
		"@babel/core": "^7.28.5",
		"@babel/preset-env": "^7.28.5",
		"@babel/preset-react": "^7.28.5",
		"@babel/preset-typescript": "^7.28.5",
		"@types/diff": "^7.0.0",
		"@types/mocha": "^10.0.9",
		"@types/node": "20.x",
		"@types/path-browserify": "^1.0.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/uuid": "^10.0.0",
		"@types/vscode": "^1.93.0",
		"@typescript-eslint/eslint-plugin": "^8.10.0",
		"@typescript-eslint/parser": "^8.7.0",
		"@vscode/test-cli": "^0.0.10",
		"@vscode/test-electron": "^2.4.1",
		"autoprefixer": "^10.4.20",
		"babel-loader": "^10.0.0",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^9.2.1",
		"copy-webpack-plugin": "^13.0.1",
		"cross-env": "^7.0.3",
		"css-loader": "^6.11.0",
		"dotenv": "^17.2.1",
		"esbuild-loader": "^4.4.0",
		"eslint": "^9.13.0",
		"postcss": "^8.4.47",
		"postcss-loader": "^8.1.1",
		"process": "^0.11.10",
		"style-loader": "^3.3.4",
		"tailwindcss": "^3.4.14",
		"ts-loader": "^9.5.1",
		"tsx": "^4.20.6",
		"typescript": "^5.6.3",
		"webpack": "^5.95.0",
		"webpack-cli": "^5.1.4"
	},
